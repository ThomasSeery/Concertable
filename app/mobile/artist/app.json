{
  "expo": {
    "name": "Concertable Artist",
    "slug": "concertable-artist",
    "scheme": "concertable-artist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "../assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "../assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.concertable.artist",
      "supportsTablet": true
    },
    "android": {
      "package": "com.concertable.artist",
      "adaptiveIcon": {
        "foregroundImage": "../assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "../assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-image-picker",
      ["@stripe/stripe-react-native", { "merchantIdentifier": "merchant.concertable.artist" }]
    ]
  }
}
