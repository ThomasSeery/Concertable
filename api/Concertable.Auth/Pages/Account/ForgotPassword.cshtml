@page
@model Concertable.Auth.Pages.Account.ForgotPasswordModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Forgot password</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-purple-600 to-pink-500 flex items-center justify-center font-sans">
    <form method="post" class="bg-white p-8 rounded-2xl shadow-2xl w-96">
        <h1 class="text-2xl font-bold mb-6 text-gray-800">Forgot your password?</h1>

        @if (Model.Submitted)
        {
            <p class="text-gray-700 text-sm mb-4">If an account exists for that email, a password reset link has been sent.</p>
            <a href="/Account/Login" class="text-purple-600 hover:underline text-sm">Back to sign in</a>
        }
        else
        {
            <p class="text-gray-600 text-sm mb-4">Enter your email and we'll send you a reset link.</p>
            <input asp-for="Email" type="email" class="w-full px-4 py-2 border rounded mb-6 focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="Email" required />
            <button type="submit" class="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded font-semibold transition">Send reset link</button>
        }
    </form>
</body>
</html>
