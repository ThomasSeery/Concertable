@page
@model Concertable.Auth.Pages.Account.ForgotPasswordModel
@{ ViewData["Title"] = "Forgot password"; }

<div class="space-y-4">
    <h1 class="text-2xl font-bold text-white">Forgot your password?</h1>

    @if (Model.Submitted)
    {
        <p class="text-zinc-300 text-sm">If an account exists for that email, a password reset link has been sent.</p>
        <a href="/Account/Login" class="text-purple-400 hover:underline text-sm">Back to sign in</a>
    }
    else
    {
        <form method="post" class="space-y-4">
            <p class="text-zinc-400 text-sm">Enter your email and we'll send you a reset link.</p>

            <input asp-for="Email" type="email"
                   class="w-full px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-purple-500"
                   placeholder="Email" required />

            <button type="submit"
                    class="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-semibold transition">
                Send reset link
            </button>
        </form>
    }
</div>
