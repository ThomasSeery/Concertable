@page
@model Concertable.Auth.Pages.Account.ResetPasswordModel
@{ ViewData["Title"] = "Reset password"; }

<div class="space-y-4">
    <h1 class="text-2xl font-bold text-white">Set a new password</h1>

    @if (Model.Success)
    {
        <p class="text-green-400 text-sm">Your password has been reset.</p>
        <a href="/Account/Login" class="text-purple-400 hover:underline text-sm">Sign in</a>
    }
    else
    {
        <form method="post" class="space-y-4">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="text-red-400 text-sm">@Model.ErrorMessage</div>
            }

            <input asp-for="NewPassword" type="password"
                   class="w-full px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-purple-500"
                   placeholder="New password" required minlength="8" />
            <input asp-for="Token" type="hidden" />

            <button type="submit"
                    class="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-semibold transition">
                Reset password
            </button>
        </form>
    }
</div>
