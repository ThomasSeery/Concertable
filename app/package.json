{
  "name": "concertable-app",
  "private": true,
  "workspaces": [
    "web/shared",
    "web/customer",
    "web/venue",
    "web/artist",
    "web/business",
    "mobile/customer",
    "mobile/venue",
    "mobile/artist",
    "shared"
  ],
  "scripts": {
    "dev:customer": "npm -w @concertable/web-customer run dev",
    "dev:venue": "npm -w @concertable/web-venue run dev",
    "dev:artist": "npm -w @concertable/web-artist run dev",
    "dev:business": "npm -w @concertable/web-business run dev",
    "dev:mobile:customer": "npm -w @concertable/mobile-customer run start",
    "dev:mobile:venue": "npm -w @concertable/mobile-venue run start",
    "dev:mobile:artist": "npm -w @concertable/mobile-artist run start",
    "build:customer": "npm -w @concertable/web-customer run build",
    "build:venue": "npm -w @concertable/web-venue run build",
    "build:artist": "npm -w @concertable/web-artist run build",
    "build:business": "npm -w @concertable/web-business run build",
    "postinstall": "node scripts/patch-nativewind.js"
  },
  "overrides": {
    "react-native-css-interop": {
      "tailwindcss": "^3"
    },
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "react": "19.1.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.1.0",
    "react-native-worklets": "0.5.1"
  }
}
