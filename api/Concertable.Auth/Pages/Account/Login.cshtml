@page
@model Concertable.Auth.Pages.Account.LoginModel
@{ ViewData["Title"] = "Sign in to Concertable"; }

<form method="post" class="space-y-4">
    <h1 class="text-2xl font-bold text-gray-900">Sign in</h1>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="text-red-600 text-sm">@Model.ErrorMessage</div>
    }

    <input asp-for="Email" type="email"
           class="w-full px-4 py-2 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary"
           placeholder="Email" required />
    <input asp-for="Password" type="password"
           class="w-full px-4 py-2 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary"
           placeholder="Password" required />

    <input asp-for="ReturnUrl" type="hidden" />

    <button type="submit"
            class="w-full py-2 bg-primary text-primary-foreground hover:bg-primary/90 rounded-lg font-semibold transition">
        Sign in
    </button>

    <p class="text-sm text-gray-500 text-center">
        <a href="/Account/ForgotPassword" class="text-primary hover:underline">Forgot password?</a>
    </p>

    <p class="text-sm text-gray-500 text-center">
        Don't have an account? <a href="/Account/Register" class="text-primary hover:underline">Sign up</a>
    </p>
</form>
