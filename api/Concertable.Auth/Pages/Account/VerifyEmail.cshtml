@page
@model Concertable.Auth.Pages.Account.VerifyEmailModel
@{ ViewData["Title"] = "Verify email"; }

<div class="space-y-4 text-center">
    @if (Model.Success)
    {
        <h1 class="text-2xl font-bold text-gray-900">Email verified</h1>
        <p class="text-gray-500 text-sm">Your email has been verified.</p>
        <a href="/Account/Login"
           class="inline-block py-2 px-6 bg-primary text-primary-foreground hover:bg-primary/90 rounded-lg font-semibold transition">
            Sign in
        </a>
    }
    else
    {
        <h1 class="text-2xl font-bold text-gray-900">Verification failed</h1>
        <p class="text-red-600 text-sm">This verification link is invalid or has expired.</p>
    }
</div>
