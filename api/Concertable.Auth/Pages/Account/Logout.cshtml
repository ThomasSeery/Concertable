@page
@model Concertable.Auth.Pages.Account.LogoutModel
@{ ViewData["Title"] = "Sign out"; }

<form method="post" class="space-y-4 text-center">
    <h1 class="text-2xl font-bold text-gray-900">Sign out</h1>
    <p class="text-gray-600">Are you sure you want to sign out?</p>

    <input asp-for="LogoutId" type="hidden" />

    <button type="submit"
            class="w-full py-2 bg-primary text-primary-foreground hover:bg-primary/90 rounded-lg font-semibold transition">
        Sign out
    </button>
</form>
