@page
@model Concertable.Auth.Pages.Account.LoginModel
@{ ViewData["Title"] = "Sign in to Concertable"; }

<form method="post" class="space-y-4">
    <h1 class="text-2xl font-bold text-white">Sign in</h1>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="text-red-400 text-sm">@Model.ErrorMessage</div>
    }

    <input asp-for="Email" type="email"
           class="w-full px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-purple-500"
           placeholder="Email" required />
    <input asp-for="Password" type="password"
           class="w-full px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-purple-500"
           placeholder="Password" required />

    <input asp-for="ReturnUrl" type="hidden" />

    <button type="submit"
            class="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-semibold transition">
        Sign in
    </button>

    <p class="text-sm text-zinc-400 text-center">
        <a href="/Account/ForgotPassword" class="text-purple-400 hover:underline">Forgot password?</a>
    </p>

    <p class="text-sm text-zinc-400 text-center">
        Don't have an account? <a href="/Account/Register" class="text-purple-400 hover:underline">Sign up</a>
    </p>
</form>
