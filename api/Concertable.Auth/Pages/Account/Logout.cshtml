@page
@model Concertable.Auth.Pages.Account.LogoutModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Sign out</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-purple-600 to-pink-500 flex items-center justify-center font-sans">
    <form method="post" class="bg-white p-8 rounded-2xl shadow-2xl w-96 text-center">
        <h1 class="text-2xl font-bold mb-4 text-gray-800">Sign out</h1>
        <p class="text-gray-600 mb-6">Are you sure you want to sign out?</p>

        <input asp-for="LogoutId" type="hidden" />

        <button type="submit" class="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded font-semibold transition">Sign out</button>
    </form>
</body>
</html>
