{
  "name": "concertable-app",
  "private": true,
  "workspaces": [
    "web/customer",
    "web/venue",
    "web/artist",
    "web/business",
    "mobile/customer",
    "mobile/business",
    "shared"
  ],
  "scripts": {
    "dev:customer": "npm -w @concertable/web-customer run dev",
    "dev:venue": "npm -w @concertable/web-venue run dev",
    "dev:artist": "npm -w @concertable/web-artist run dev",
    "dev:business": "npm -w @concertable/web-business run dev",
    "dev:mobile:customer": "npm -w @concertable/mobile-customer run start",
    "dev:mobile:business": "npm -w @concertable/mobile-business run start",
    "build:customer": "npm -w @concertable/web-customer run build",
    "build:venue": "npm -w @concertable/web-venue run build",
    "build:artist": "npm -w @concertable/web-artist run build",
    "build:business": "npm -w @concertable/web-business run build",
    "postinstall": "node scripts/patch-nativewind.js"
  },
  "overrides": {
    "react-native-css-interop": {
      "tailwindcss": "^3"
    },
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5",
    "@stripe/react-stripe-js": "^3",
    "@stripe/stripe-js": "^4",
    "@tanstack/react-router": "^1",
    "@tanstack/router-devtools": "^1",
    "@vis.gl/react-google-maps": "^1",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "embla-carousel-react": "^8",
    "framer-motion": "^12",
    "lucide-react": "^0.468",
    "radix-ui": "^1",
    "react": "19.1.0",
    "react-day-picker": "^9",
    "react-dom": "19.1.0",
    "react-native-worklets": "0.5.1",
    "react-oidc-context": "^3",
    "shadcn": "^4.7.0",
    "sonner": "^2",
    "tailwind-merge": "^3",
    "tw-animate-css": "^1.4.0",
    "use-places-autocomplete": "^4"
  }
}
