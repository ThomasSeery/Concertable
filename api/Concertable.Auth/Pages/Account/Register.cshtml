@page
@using Concertable.User.Contracts
@model Concertable.Auth.Pages.Account.RegisterModel
@{ ViewData["Title"] = "Create your Concertable account"; }

<div class="space-y-4">
    <h1 class="text-2xl font-bold text-gray-900">Create your account</h1>

    @if (Model.Submitted)
    {
        <p class="text-gray-700 text-sm">Account created. Check your email for a verification link.</p>
        <a href="/Account/Login" class="text-primary hover:underline text-sm">Sign in</a>
    }
    else
    {
        <form method="post" class="space-y-4">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="text-red-600 text-sm">@Model.ErrorMessage</div>
            }

            <input asp-for="Email" type="email"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary"
                   placeholder="Email" required />
            <input asp-for="Password" type="password"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary"
                   placeholder="Password" required minlength="8" />
            <select asp-for="Role"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary"
                    required>
                <option value="@Role.Customer">Customer</option>
                <option value="@Role.VenueManager">Venue manager</option>
                <option value="@Role.ArtistManager">Artist manager</option>
            </select>

            <button type="submit"
                    class="w-full py-2 bg-primary text-primary-foreground hover:bg-primary/90 rounded-lg font-semibold transition">
                Create account
            </button>

            <p class="text-sm text-gray-500 text-center">
                Already have one? <a href="/Account/Login" class="text-primary hover:underline">Sign in</a>
            </p>
        </form>
    }
</div>
