@page
@model Concertable.Auth.Pages.Account.VerifyEmailModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Verify email</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-purple-600 to-pink-500 flex items-center justify-center font-sans">
    <div class="bg-white p-8 rounded-2xl shadow-2xl w-96 text-center">
        @if (Model.Success)
        {
            <h1 class="text-2xl font-bold mb-4 text-gray-800">Email verified</h1>
            <p class="text-gray-600 text-sm mb-6">Your email has been verified.</p>
            <a href="/Account/Login" class="inline-block py-2 px-6 bg-purple-600 hover:bg-purple-700 text-white rounded font-semibold transition">Sign in</a>
        }
        else
        {
            <h1 class="text-2xl font-bold mb-4 text-gray-800">Verification failed</h1>
            <p class="text-red-600 text-sm">This verification link is invalid or has expired.</p>
        }
    </div>
</body>
</html>
