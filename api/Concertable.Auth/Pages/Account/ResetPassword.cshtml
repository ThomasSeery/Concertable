@page
@model Concertable.Auth.Pages.Account.ResetPasswordModel
@{ ViewData["Title"] = "Reset password"; }

<div class="space-y-4">
    <h1 class="text-2xl font-bold text-gray-900">Set a new password</h1>

    @if (Model.Success)
    {
        <p class="text-green-600 text-sm">Your password has been reset.</p>
        <a href="/Account/Login" class="text-primary hover:underline text-sm">Sign in</a>
    }
    else
    {
        <form method="post" class="space-y-4">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="text-red-600 text-sm">@Model.ErrorMessage</div>
            }

            <input asp-for="NewPassword" type="password"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary"
                   placeholder="New password" required minlength="8" />
            <input asp-for="Token" type="hidden" />

            <button type="submit"
                    class="w-full py-2 bg-primary text-primary-foreground hover:bg-primary/90 rounded-lg font-semibold transition">
                Reset password
            </button>
        </form>
    }
</div>
