@page
@model Concertable.Auth.Pages.Account.LogoutModel
@{ ViewData["Title"] = "Sign out"; }

<form method="post" class="space-y-4 text-center">
    <h1 class="text-2xl font-bold text-white">Sign out</h1>
    <p class="text-zinc-400">Are you sure you want to sign out?</p>

    <input asp-for="LogoutId" type="hidden" />

    <button type="submit"
            class="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-semibold transition">
        Sign out
    </button>
</form>
