@page
@using Concertable.User.Contracts
@model Concertable.Auth.Pages.Account.RegisterModel
@{ ViewData["Title"] = "Create your Concertable account"; }

<div class="space-y-4">
    <h1 class="text-2xl font-bold text-white">Create your account</h1>

    @if (Model.Submitted)
    {
        <p class="text-zinc-300 text-sm">Account created. Check your email for a verification link.</p>
        <a href="/Account/Login" class="text-purple-400 hover:underline text-sm">Sign in</a>
    }
    else
    {
        <form method="post" class="space-y-4">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="text-red-400 text-sm">@Model.ErrorMessage</div>
            }

            <input asp-for="Email" type="email"
                   class="w-full px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-purple-500"
                   placeholder="Email" required />
            <input asp-for="Password" type="password"
                   class="w-full px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-purple-500"
                   placeholder="Password" required minlength="8" />
            <select asp-for="Role"
                    class="w-full px-4 py-2 bg-zinc-800 border border-zinc-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-purple-500"
                    required>
                <option value="@Role.Customer">Customer</option>
                <option value="@Role.VenueManager">Venue manager</option>
                <option value="@Role.ArtistManager">Artist manager</option>
            </select>

            <button type="submit"
                    class="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-semibold transition">
                Create account
            </button>

            <p class="text-sm text-zinc-400 text-center">
                Already have one? <a href="/Account/Login" class="text-purple-400 hover:underline">Sign in</a>
            </p>
        </form>
    }
</div>
