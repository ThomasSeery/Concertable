@page
@using Concertable.User.Contracts
@model Concertable.Auth.Pages.Account.RegisterModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Create your Concertable account</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-purple-600 to-pink-500 flex items-center justify-center font-sans">
    <form method="post" class="bg-white p-8 rounded-2xl shadow-2xl w-96">
        <h1 class="text-2xl font-bold mb-6 text-gray-800">Create your account</h1>

        @if (Model.Submitted)
        {
            <p class="text-gray-700 text-sm mb-4">Account created. Check your email for a verification link.</p>
            <a href="/Account/Login" class="text-purple-600 hover:underline text-sm">Sign in</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="text-red-600 text-sm mb-3">@Model.ErrorMessage</div>
            }

            <input asp-for="Email" type="email" class="w-full px-4 py-2 border rounded mb-3 focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="Email" required />
            <input asp-for="Password" type="password" class="w-full px-4 py-2 border rounded mb-3 focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="Password" required minlength="8" />
            <select asp-for="Role" class="w-full px-4 py-2 border rounded mb-6 focus:outline-none focus:ring-2 focus:ring-purple-500" required>
                <option value="@Role.Customer">Customer</option>
                <option value="@Role.VenueManager">Venue manager</option>
                <option value="@Role.ArtistManager">Artist manager</option>
            </select>

            <button type="submit" class="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded font-semibold transition">Create account</button>

            <p class="text-sm text-gray-500 text-center mt-4">
                Already have one? <a href="/Account/Login" class="text-purple-600 hover:underline">Sign in</a>
            </p>
        }
    </form>
</body>
</html>
