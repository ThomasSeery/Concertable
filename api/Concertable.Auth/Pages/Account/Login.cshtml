@page
@model Concertable.Auth.Pages.Account.LoginModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Sign in to Concertable</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-purple-600 to-pink-500 flex items-center justify-center font-sans">
    <form method="post" class="bg-white p-8 rounded-2xl shadow-2xl w-96">
        <h1 class="text-2xl font-bold mb-6 text-gray-800">Sign in to Concertable</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="text-red-600 text-sm mb-3">@Model.ErrorMessage</div>
        }

        <input asp-for="Email"    type="email"    class="w-full px-4 py-2 border rounded mb-3 focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="Email" required />
        <input asp-for="Password" type="password" class="w-full px-4 py-2 border rounded mb-6 focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="Password" required />

        <input asp-for="ReturnUrl" type="hidden" />

        <button type="submit" class="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded font-semibold transition">Sign in</button>
    </form>
</body>
</html>
