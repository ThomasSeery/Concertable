@page
@model Concertable.Auth.Pages.Account.ChangePasswordModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Change password</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-purple-600 to-pink-500 flex items-center justify-center font-sans">
    <form method="post" class="bg-white p-8 rounded-2xl shadow-2xl w-96">
        <h1 class="text-2xl font-bold mb-6 text-gray-800">Change your password</h1>

        @if (Model.Success)
        {
            <p class="text-green-700 text-sm mb-4">Password updated.</p>
            <a href="/" class="text-purple-600 hover:underline text-sm">Back</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="text-red-600 text-sm mb-3">@Model.ErrorMessage</div>
            }

            <input asp-for="CurrentPassword" type="password" class="w-full px-4 py-2 border rounded mb-3 focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="Current password" required />
            <input asp-for="NewPassword" type="password" class="w-full px-4 py-2 border rounded mb-6 focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="New password" required minlength="8" />
            <button type="submit" class="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded font-semibold transition">Update password</button>
        }
    </form>
</body>
</html>
