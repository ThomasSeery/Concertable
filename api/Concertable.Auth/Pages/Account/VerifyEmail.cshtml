@page
@model Concertable.Auth.Pages.Account.VerifyEmailModel
@{ ViewData["Title"] = "Verify email"; }

<div class="space-y-4 text-center">
    @if (Model.Success)
    {
        <h1 class="text-2xl font-bold text-white">Email verified</h1>
        <p class="text-zinc-400 text-sm">Your email has been verified.</p>
        <a href="/Account/Login"
           class="inline-block py-2 px-6 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-semibold transition">
            Sign in
        </a>
    }
    else
    {
        <h1 class="text-2xl font-bold text-white">Verification failed</h1>
        <p class="text-red-400 text-sm">This verification link is invalid or has expired.</p>
    }
</div>
