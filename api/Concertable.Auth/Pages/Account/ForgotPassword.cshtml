@page
@model Concertable.Auth.Pages.Account.ForgotPasswordModel
@{ ViewData["Title"] = "Forgot password"; }

<div class="space-y-4">
    <h1 class="text-2xl font-bold text-gray-900">Forgot your password?</h1>

    @if (Model.Submitted)
    {
        <p class="text-gray-700 text-sm">If an account exists for that email, a password reset link has been sent.</p>
        <a href="/Account/Login" class="text-primary hover:underline text-sm">Back to sign in</a>
    }
    else
    {
        <form method="post" class="space-y-4">
            <p class="text-gray-500 text-sm">Enter your email and we'll send you a reset link.</p>

            <input asp-for="Email" type="email"
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary"
                   placeholder="Email" required />

            <button type="submit"
                    class="w-full py-2 bg-primary text-primary-foreground hover:bg-primary/90 rounded-lg font-semibold transition">
                Send reset link
            </button>
        </form>
    }
</div>
